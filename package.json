{
  "name": "tsukinome",
  "version": "0.1.0",
  "description": "A GitHub-native agent that turns a natural-language issue into a high-quality, test-first pull request.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "migrate": "node-pg-migrate",
    "dev:smee": "smee --url $SMEE_URL --path /api/github/webhooks --port 3000"
  },
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.22.0",
    "probot": "^14.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.5",
    "smee-client": "^5.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  }
}
